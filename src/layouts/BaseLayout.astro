---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'CIBI Lab', description = 'Computational Intelligence in Biomedical Imaging Laboratory, NTU' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | CIBI Lab</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=Noto+Sans+TC:wght@300;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  <ViewTransitions />
</head>
<body class="bg-page min-h-screen">
  <Navbar />
  <main transition:animate="slide">
    <slot />
  </main>
  <Footer />

  <!-- Language state initialisation -->
  <script>
    if (!localStorage.getItem('lang')) {
      localStorage.setItem('lang', 'en');
    }
    document.documentElement.setAttribute('data-lang', localStorage.getItem('lang') || 'en');
  </script>
</body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <section class="max-w-2xl mx-auto px-4 sm:px-6 pt-32 pb-24 text-center">
    <img
      src="/assets/logo/CIBI_Lab_logo.png"
      alt="CIBI Lab"
      class="h-12 w-auto mx-auto mb-8 opacity-40"
      onerror="this.style.display='none'"
    />
    <h1 class="text-6xl font-medium mb-4" style="color: var(--color-brand-light);">404</h1>
    <p class="text-xl font-medium mb-3" style="color: var(--color-heading);">Page Not Found</p>
    <p class="text-sm mb-8" style="color: var(--color-muted);">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full text-sm font-medium text-white transition-colors duration-150"
      style="background: var(--color-brand);"
    >
      ← Back to Home
    </a>
  </section>
</BaseLayout>

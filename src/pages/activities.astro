---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Activities">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-14 pb-24">
    <h1 class="text-3xl font-medium mb-10" style="color: var(--color-heading);">
      <span data-en="Activities" data-zh="活動紀錄">Activities</span>
    </h1>
    <div id="activities-container" class="relative">
      <!-- Vertical connector line -->
      <div class="absolute left-1/2 top-0 bottom-0 w-px hidden md:block" style="background:#D6E4F0; transform:translateX(-50%);"></div>
      <p class="text-sm" style="color: var(--color-muted);">Loading activities…</p>
    </div>
  </section>
</BaseLayout>

<script>
  import anime from 'animejs/lib/anime.es.js';
  import { fetchGallery } from '../lib/parseGallery';
  import { SHEETS } from '../constants/sheets';
  import type { GalleryItem } from '../types/index';

  function photoSrc(filename: string) {
    return filename ? `/assets/gallery/${filename}` : '/assets/gallery/default.jpg';
  }

  function activityCard(item: GalleryItem, lang: string): string {
    const title = lang === 'zh' ? (item.title_zh || item.title_en) : item.title_en;
    const date = item.date;
    const isAcademic = item.type === 'academic';
    const typeLabel = isAcademic
      ? (lang === 'zh' ? '學術' : 'Academic')
      : (lang === 'zh' ? '課外' : 'Extracurricular');
    const typeBg = isAcademic ? '#E6F1FB' : '#EEEDFE';
    const typeColor = isAcademic ? '#0C447C' : '#3C3489';
    const remarkHtml = item.remark
      ? `<hr style="border-color:var(--color-brand-light); margin:8px 0 6px;" /><p class="text-xs" style="color:var(--color-body);">${item.remark}</p>`
      : '';

    return `<div class="activity-card anim-hidden flex-shrink-0 rounded-xl overflow-hidden border" style="width:180px; background:var(--color-surface); border-color:var(--color-brand-light);">
      <div style="width:180px; aspect-ratio:4/3; background:var(--color-brand-wash); overflow:hidden;">
        <img src="${photoSrc(item.photo_filename)}" alt="${title}" style="width:100%; height:100%; object-fit:cover;"
          onerror="this.parentElement.style.background='var(--color-brand-wash)'" />
      </div>
      <div class="p-3">
        <p class="text-xs font-medium leading-snug mb-1" style="color:var(--color-heading);">${title}</p>
        <p class="text-xs mb-2" style="color:var(--color-muted);">${date}</p>
        <span class="pill text-xs" style="background:${typeBg}; color:${typeColor}; padding:1px 8px; border:none;">${typeLabel}</span>
        ${remarkHtml}
      </div>
    </div>`;
  }

  async function renderActivities() {
    const container = document.getElementById('activities-container');
    if (!container) return;

    let items: GalleryItem[] = [];
    try {
      items = await fetchGallery(SHEETS.gallery);
    } catch {
      container.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">Unable to load activities data.</p>';
      return;
    }

    const lang = localStorage.getItem('lang') || 'en';

    // Group by year desc
    items.sort((a, b) => b.date.localeCompare(a.date));
    const byYear = new Map<number, GalleryItem[]>();
    for (const item of items) {
      const year = parseInt(item.date.split('-')[0]);
      if (!byYear.has(year)) byYear.set(year, []);
      byYear.get(year)!.push(item);
    }

    const years = Array.from(byYear.keys()).sort((a, b) => b - a);

    let html = '<div class="absolute left-1/2 top-0 bottom-0 w-px hidden md:block" style="background:#D6E4F0; transform:translateX(-50%);"></div>';

    years.forEach((year, idx) => {
      const isLeft = idx % 2 === 0;
      const alignClass = isLeft ? 'md:pr-[52%]' : 'md:pl-[52%]';
      const cards = byYear.get(year)!;

      html += `<div class="year-group anim-hidden mb-16 ${alignClass}">
        <div class="mb-4">
          <span class="text-5xl font-medium" style="color:#D6E4F0; font-size:3rem;">${year}</span>
          <div class="h-0.5 w-10 mt-1" style="background:var(--color-brand);"></div>
        </div>
        <div class="flex gap-4 overflow-x-auto pb-2" style="scrollbar-width:thin;">
          ${cards.map(item => activityCard(item, lang)).join('')}
        </div>
      </div>`;
    });

    if (!html.includes('activity-card')) {
      container.innerHTML = '<p style="color:var(--color-muted); font-size:0.875rem;">No activities yet.</p>';
      return;
    }

    container.innerHTML = html;
    animateYearGroups();
  }

  function animateYearGroups() {
    document.querySelectorAll('.year-group').forEach(group => {
      const observer = new IntersectionObserver(entries => {
        if (!entries[0].isIntersecting) return;
        anime({ targets: group, opacity: [0, 1], translateY: [8, 0], duration: 350, easing: 'easeOutQuad' });
        anime({
          targets: Array.from(group.querySelectorAll('.activity-card')),
          opacity: [0, 1],
          translateX: [-12, 0],
          delay: anime.stagger(80),
          duration: 350,
          easing: 'easeOutQuad',
        });
        observer.disconnect();
      }, { threshold: 0.1 });
      observer.observe(group);
    });
  }

  renderActivities();
  document.addEventListener('langchange', renderActivities);
  document.addEventListener('astro:after-swap', renderActivities);
</script>
